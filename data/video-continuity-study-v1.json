{"name":"FaceSwapAI Controlled Production Video Face-Swap Study","version":"1.0.0","status":"published","published":"2026-07-14","modified":"2026-07-14","dataLicense":"https://creativecommons.org/licenses/by/4.0/","webpage":"https://faceswapai.com/resources/video-face-swap-continuity-study","dataset":"https://faceswapai.com/video-continuity-study-v1.json","visualization":"/research/video-continuity-study-v1.jpg","inputVideo":"/research/video-continuity-input-v1.mp4","outputVideo":"/research/video-continuity-output-v1.mp4","purpose":"A controlled, inspectable production run measuring container preservation, sampled face detection, face-box alignment and regional pixel differences across one synthetic 10-second video face swap.","design":{"identityBoundary":"Both adult identities are purpose-built synthetic portraits. No customer media, real public figure or face-recognition identity label is used.","sourcePortrait":{"asset":"/research/video-continuity-source-v1.jpg","width":1024,"height":1024,"bytes":157351,"sha256":"5f6aa1a771c4940ed053d2dce3932f5c360840511e80893e72b507c5eaa05b59"},"targetStates":[{"state":"neutral","asset":"/research/video-continuity-target-v1.jpg","width":1280,"height":720,"bytes":90367,"sha256":"63c09dbb71e930e48d2cf7d8075a7fbfe0c475c76e1b982c873b9f808a623f32"},{"state":"left turn","asset":"/research/video-continuity-target-left-v1.jpg","width":1280,"height":720,"bytes":92182,"sha256":"bae93c8603325392ef99987b545a14e394b4834b48d2c57a84736b3e54f17d7e"},{"state":"blink","asset":"/research/video-continuity-target-blink-v1.jpg","width":1280,"height":720,"bytes":94320,"sha256":"3c0e1b2b6c5340d972d727859541333e546e2d4cb5a7dd05e71303bf73bbc635"},{"state":"right turn","asset":"/research/video-continuity-target-right-v1.jpg","width":1280,"height":720,"bytes":93738,"sha256":"d0852d61b96edc80c5e437c59925964b5a61d2e4d65fddabddb4ea4abf9e72c2"}],"targetConstruction":"Six still segments use documented crossfades, subtle deterministic camera drift and a one-second light dip. The input has no audio stream.","productionRun":{"route":"/api/v1/face-swap/video","observedStatus":"COMPLETED","creditsUsed":10,"accountBoundary":"A temporary verified test account was used and deleted with its task, logs, uploads and server-side output after the public research copy was secured."}},"containers":{"input":{"codec":"h264","pixelFormat":"yuvj420p","width":1280,"height":720,"frameRate":"24/1","frameCount":240,"durationSeconds":10,"bytes":956633,"sha256":"3a8cefeb1e69d433ff171f2639c15c9d45e9d87932dba8c046c4105653af7f1f"},"output":{"codec":"h264","pixelFormat":"yuv420p","width":1280,"height":720,"frameRate":"24/1","frameCount":240,"durationSeconds":10,"bytes":1329222,"sha256":"8cd3b9ac4dfdc62c635d5bf0e00cb01b3c6ecd23cc08efdb0ec1dccd1592ad77"}},"measurement":{"capturedAt":"2026-07-14T12:04:42.582Z","sampleTimestampsSeconds":[0.5,1.5,2.5,3.5,4.5,6.5,8,9.5],"faceDetection":"FaceSwapAI production public detector v1.0; count and bounding boxes only, with no crops, embeddings or identity comparison.","faceBoxIoU":"Intersection over union between the first returned input and output face boxes at the same timestamp.","centerDisplacement":"Euclidean distance between the input and output box centers in pixels and as a share of the input face-box diagonal.","faceSharpness":"Variance of a four-neighbor luminance Laplacian inside each face box plus 12% padding, normalized to 160 by 160 pixels.","luminance":"Whole-frame metrics after reducing the longest side to 360 pixels; brightness uses 0.2126 red + 0.7152 green + 0.0722 blue.","pixelDifference":"Mean absolute RGB difference compares matched decoded input and output frames. The face region is the union of both face boxes after 20% padding; all remaining pixels form the outside region.","changedPixelThreshold":"A pixel is counted as changed when mean absolute RGB difference is at least 12 on an 8-bit channel scale."},"summary":{"sampledFramePairs":8,"inputDetectedSamples":8,"outputDetectedSamples":8,"i