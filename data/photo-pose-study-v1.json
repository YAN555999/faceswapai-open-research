    "capturedAt": "2026-07-15T05:38:54.455Z",
    "faceDetection": "FaceSwapAI production public detector v1.0 logic; count and bounding boxes only, with no crops, embeddings or identity comparison retained.",
    "faceBoxIoU": "Intersection over union between the target and output face boxes for the same state.",
    "centerDisplacement": "Euclidean distance between target and output face-box centers, in pixels and as a share of the target face-box diagonal.",
    "faceSharpness": "Variance of a four-neighbor luminance Laplacian inside each face box plus 12% padding, normalized to 160 by 160 pixels.",
    "luminance": "Whole-image metrics after reducing the longest side to 360 pixels; brightness uses 0.2126 red + 0.7152 green + 0.0722 blue.",
    "pixelDifference": "Mean absolute RGB difference between the target and output. The face region is the union of both face boxes after 20% padding; all remaining pixels form the outside region.",
    "changedPixelThreshold": "A pixel is counted as changed when mean absolute RGB difference is at least 12 on an 8-bit channel scale."
  },
